# Dependencies
node_modules/

# Build output
client/dist/
client/.vite/

# Environment files — NEVER commit these
.env
.env.local
.env.*.local
server/.env
client/.env

# PWA icons (generated from SVG via npm run icons)
client/public/icons/*.png

# Uploads (user-generated content — store in S3 in production)
server/uploads/*
!server/uploads/.gitkeep

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/
.nyc_output/

# MongoDB memory server binary cache
.cache/
