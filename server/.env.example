PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://localhost:27017/tuition_management

JWT_SECRET=replace_with_a_strong_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_strong_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

CLIENT_ORIGIN=http://localhost:5173

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Outbound WhatsApp/SMS for parent alerts.
# console (default, logs only) | whatsapp-cloud | twilio-sms
MESSAGING_PROVIDER=console
# For whatsapp-cloud (Meta developer console):
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# For twilio-sms:
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Online payments (Razorpay). Leave blank to run the built-in simulated
# gateway — the full pay flow works locally without an account.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
